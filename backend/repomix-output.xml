  workspace.collaborators.push({
    userId: invitee.id,
    role: role ?? 'viewer',
    invitedBy: ownerId,
    acceptedAt: new Date(),
  });
  
  await WorkspaceModel.findByIdAndUpdate(workspace.id, { 
