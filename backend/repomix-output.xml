import { groqAdapter } from './ai/groq.adapter';

const MOCK_DELAY = (ms: number) => new Promise(r => setTimeout(r, ms));

interface GenerationOptions {
  prompt: string;
  previousArchitecture?: ArchitectureData;
  designData?: any;
